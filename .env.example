# BrickGen Environment Configuration

# API Key (Required)
# Get your Rebrickable API key from: https://rebrickable.com/api/
REBRICKABLE_API_KEY=your_rebrickable_api_key_here

# Authentication (Default: brickgen/brickgen)
# Set your login credentials for the web interface
# For better security, change these from the defaults
AUTH_USERNAME=brickgen
AUTH_PASSWORD=brickgen

# JWT Secret Key (Optional but recommended)
# Generate a secure random secret key: openssl rand -hex 32
# Example: 09d25e094faa6ca2556c818166b7a9563b93f7099f6f0f4caa6cf63b88e8d3e7
JWT_SECRET_KEY=your_secret_key_here_change_in_production

# Logging (Optional: DEBUG, INFO, WARNING, ERROR, CRITICAL. Default: INFO)
LOG_LEVEL=INFO

# Build Plate Defaults (Optional)
DEFAULT_PLATE_WIDTH=220
DEFAULT_PLATE_DEPTH=220
DEFAULT_PLATE_HEIGHT=250
PART_SPACING=2

# Paths (Optional - defaults work for Docker)
LDRAW_LIBRARY_PATH=/app/data/ldraw
CACHE_DIR=/app/cache
DATABASE_PATH=/app/database/brickgen.db
